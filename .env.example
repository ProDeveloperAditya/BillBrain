# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL 15+ connection string.
#
# FREE option (recommended): Neon — https://neon.tech  (no credit card)
#   1. Create a project, then open "Connection Details".
#   2. Copy the connection string. Use the DIRECT (non-pooled) string — the host
#      should NOT contain "-pooler". The direct string works for both the app and
#      for `prisma migrate deploy`. (The pooled string cannot run migrations.)
#   3. Append `?sslmode=require&connect_timeout=15&pool_timeout=15`. The timeouts
#      give Prisma time to wake Neon from auto-suspend, preventing intermittent
#      "this page couldn't load" 500s on the first request after the DB idles.
#
# Example:
#   postgresql://USER:PASSWORD@ep-xxxx.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&pool_timeout=15
DATABASE_URL="postgresql://user:password@localhost:5432/billbrain?sslmode=require&connect_timeout=15&pool_timeout=15"

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# AUTH_SECRET: random string used to sign JWTs and session cookies.
#   Generate one with:  openssl rand -base64 32   (or: npx auth secret)
# NOTE: Auth.js v5 reads AUTH_SECRET. NEXTAUTH_SECRET is kept as a legacy alias —
#   set both to the SAME value to be safe.
AUTH_SECRET="your-random-secret-here"
NEXTAUTH_SECRET="your-random-secret-here"

# Optional. With trustHost enabled the app infers its URL from the request, so
# you usually do NOT need to set this. Set it only if you hit host issues.
# NEXTAUTH_URL="https://your-app.vercel.app"

# ─── AI Providers ─────────────────────────────────────────────────────────────
# All AI keys are OPTIONAL. With no key the app runs in demo mode at zero cost.
# AI_PROVIDER: openai | groq | demo
#   If unset, the app auto-selects the first available key (OpenAI → Groq → demo).
AI_PROVIDER="demo"

# OpenAI — best quality (paid). https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."

# Groq — fast and has a genuinely FREE tier (no credit card). Recommended for a
# real AI assistant at $0. https://console.groq.com/keys
# GROQ_API_KEY="gsk_..."

# ─── App ──────────────────────────────────────────────────────────────────────
# Public base URL used for absolute links. Set to your Vercel URL in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
